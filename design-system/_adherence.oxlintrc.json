{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/forms/**",
              "ui_kits/booking/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Shippori Mincho|Zen Kaku Gothic New))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Shippori Mincho, Zen Kaku Gothic New."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|plum|outline|accent)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'plum' | 'outline' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|block|disabled|iconLeft|iconRight|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, block, disabled, iconLeft, iconRight, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dot|tone|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, dot, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:muted|plum|cream)$/]",
        "message": "<Eyebrow> tone must be one of 'muted' | 'plum' | 'cream'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|showTagline|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: tone, size, showTagline."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:plum|cream|ink)$/]",
        "message": "<Logo> tone must be one of 'plum' | 'cream' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|duration|regular|now|description|image|rank|emphasis|key|ref|className|style|children)$/]",
        "message": "<MenuCard> doesn't accept that prop. Declared props: name, duration, regular, now, description, image, rank, emphasis."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuCard'] > JSXAttribute[name.name='emphasis'] > Literal[value!=/^(?:plum|accent)$/]",
        "message": "<MenuCard> emphasis must be one of 'plum' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:duration|regular|now|note|emphasis|size|key|ref|className|style|children)$/]",
        "message": "<PriceTag> doesn't accept that prop. Declared props: duration, regular, now, note, emphasis, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute[name.name='emphasis'] > Literal[value!=/^(?:plum|accent)$/]",
        "message": "<PriceTag> emphasis must be one of 'plum' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PriceTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|lead|align|titleFont|divider|tone|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: eyebrow, title, lead, align, titleFont, divider, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHeader> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='titleFont'] > Literal[value!=/^(?:serif-jp|display)$/]",
        "message": "<SectionHeader> titleFont must be one of 'serif-jp' | 'display'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<SectionHeader> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|rows|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, hint, error, rows."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
